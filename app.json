      },
      {
        "pagePath": "pages/map/index",
        "text": "消费足迹",
        "iconPath": "images/tab-map.png",
        "selectedIconPath": "images/tab-map.png"
      },
      {
        "pagePath": "pages/shelf/index",
        "text": "咖啡架",
        "iconPath": "images/tab-shelf.png",
        "selectedIconPath": "images/tab-shelf.png"
      },
      {
        "pagePath": "pages/story/index",
        "text": "分享瞬间",
        "iconPath": "images/tab-story.png",
        "selectedIconPath": "images/tab-story.png"
      }
    ]
