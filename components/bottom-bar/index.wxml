<view class="tab-bar">
  <view
    class="tab-bar__item"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    bindtap="onTap"
  >
    <image class="tab-bar__icon" src="{{item.iconPath}}" mode="aspectFit" />
    <text class="tab-bar__text">{{item.text}}</text>
  </view>
</view>
