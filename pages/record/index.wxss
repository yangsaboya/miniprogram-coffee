.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 40rpx;
  padding-bottom: calc(40rpx + 100rpx + env(safe-area-inset-bottom));
  background: radial-gradient(circle at top, #fdf6ec 0, #f7f3ee 45%, #f3eee8 100%);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部浅浅的咖啡豆装饰带 */
.page::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle at 30% 30%, rgba(111, 78, 55, 0.18), transparent 60%),
    radial-gradient(circle at 70% 70%, rgba(196, 154, 108, 0.16), transparent 65%);
  opacity: 0.9;
  pointer-events: none;
}

.weui-header {
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #6f4e37, #8b5a3c);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  color: #fdf6ec;
  position: relative;
  overflow: hidden;
}

.weui-header__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fdf6ec;
}

.weui-header__subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #f3e4d4;
}

.weui-header__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #f7f0e8;
  opacity: 0.9;
}

.weui-panel {
  margin-bottom: 24rpx;
  background-color: #fdfaf6;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 26rpx rgba(55, 40, 30, 0.04);
}

.weui-panel__hd {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #8b7b70;
  border-bottom: 1px solid #efe1d4;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.weui-panel__bd {
  padding: 8rpx 0;
}

.weui-cell {
  display: flex;
  padding: 24rpx;
  align-items: center;
  background: linear-gradient(to right, rgba(255, 255, 255, 0.9), rgba(247, 243, 238, 0.9));
}

.weui-cell + .weui-cell {
  border-top: 1px solid #f5f5f5;
}

/* 评分行：左右同高、垂直居中对齐 */
.weui-cell--rating .weui-cell__hd,
.weui-cell--rating .weui-cell__bd {
  height: 44rpx;
  display: flex;
  align-items: center;
}

.weui-cell--rating .weui-label,
.weui-cell--rating .rating-stars {
  line-height: 44rpx;
}

.weui-cell__hd {
  margin-right: 24rpx;
  display: flex;
  align-items: center;
}

.weui-label {
  font-size: 28rpx;
  color: #3a2c23;
  min-width: 120rpx;
  line-height: 1;
}

.weui-cell__bd {
  flex: 1;
  display: flex;
  align-items: center;
}

.source-group {
  display: flex;
  gap: 16rpx;
}

.source-item {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(111, 78, 55, 0.3);
  font-size: 26rpx;
  color: #5c4c40;
}

.source-item--active {
  background-color: #6f4e37;
  color: #fdf6ec;
  border-color: #6f4e37;
}

.mood-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mood-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f3eae0;
  font-size: 36rpx;
}

.mood-item--active {
  border-color: #6f4e37;
  box-shadow: 0 4rpx 10rpx rgba(111, 78, 55, 0.25);
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: -20rpx;
}

.rating-star {
  font-size: 36rpx;
  color: #d0c2b4;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.rating-star--active {
  color: #f5c26b;
}

.note-textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  padding: 12rpx 0;
  color: #3a2c23;
}

.weui-input {
  width: 100%;
  font-size: 28rpx;
  padding: 12rpx 0;
  color: #3a2c23;
}

.weui-cell--shop .weui-cell__bd {
  gap: 12rpx;
}

.weui-cell--shop .shop-input {
  flex: 1;
  min-width: 0;
}

.shop-location-btn {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(111, 78, 55, 0.35);
  background: rgba(111, 78, 55, 0.08);
  font-size: 24rpx;
  color: #6f4e37;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx 24rpx;
  box-sizing: border-box;
  row-gap: 18rpx;
}

.photo-item {
  width: 23%;
  height: 0;
  padding-bottom: 23%;
  margin-right: 3.33%;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #e6d7c8;
  box-shadow: 0 8rpx 18rpx rgba(56, 40, 30, 0.18);
  position: relative;
}

.photo-item:nth-child(3n) {
  margin-right: 0;
}

.photo-item__img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.photo-item__remark-wrap {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 4rpx 8rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.55), transparent);
  box-sizing: border-box;
}

.photo-item__remark-input {
  width: 100%;
  font-size: 20rpx;
  color: #fdf6ec;
  background: transparent;
  box-sizing: border-box;
}

.photo-remark-placeholder {
  color: rgba(253, 246, 236, 0.7);
}

.photo-item__del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 32rpx;
  line-height: 40rpx;
  text-align: center;
  z-index: 2;
}

.photo-item__del:active {
  background: rgba(0, 0, 0, 0.7);
}

.photo-add {
  width: 23%;
  height: 0;
  padding-bottom: 23%;
  margin-right: 3.33%;
  border-radius: 16rpx;
  border: 2rpx dashed #c49a6c;
  color: #8b5a3c;
  position: relative;
  box-sizing: border-box;
  background-color: rgba(253, 246, 236, 0.7);
}

.photo-add__inner {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add__icon {
  font-size: 40rpx;
  line-height: 1;
}

.photo-add__text {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.weui-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  padding: 16rpx 32rpx 32rpx;
  background: linear-gradient(to top, rgba(111, 78, 55, 0.18), rgba(247, 243, 238, 0.85), transparent);
  box-sizing: border-box;
}

.footer-btns {
  display: flex;
  gap: 16rpx;
}

.weui-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 底部双按钮：统一盒模型与内容居中，避免描边导致视觉错位 */
.footer-btns .weui-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.footer-btns .weui-btn_default {
  border-color: var(--coffee-primary, #6f4e37);
}

.footer-btns .weui-btn_primary {
  margin-top: 0;
}
