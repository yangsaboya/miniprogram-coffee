.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  background: radial-gradient(circle at top, #fdf6ec 0, #f7f3ee 45%, #f3eee8 100%);
  box-sizing: border-box;
}

.shelf-header {
  padding: 24rpx 0 32rpx;
  text-align: center;
}

.shelf-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #6f4e37;
}

.shelf-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8b7355;
}

.shelf-summary {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #a08b6e;
}

.shelf-wrap {
  margin-bottom: 32rpx;
}

.shelf-row {
  position: relative;
  margin-bottom: 32rpx;
}

.shelf-board {
  position: absolute;
  left: -16rpx;
  right: -16rpx;
  bottom: 0;
  height: 24rpx;
  background: linear-gradient(180deg, #8b6914 0, #6f4e37 30%, #5c3d2e 100%);
  border-radius: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.shelf-slots {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 8rpx 32rpx;
}

.shelf-slot {
  width: 22%;
  aspect-ratio: 1;
  background: #f7f3ee;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(111, 78, 55, 0.15);
  border: 4rpx solid #e8dfd5;
  position: relative;
  box-sizing: border-box;
}

/* 抠图展示：用页面背景底色、去掉边框，和架子融为一体 */
.shelf-slot--cutout {
  background: #f7f3ee;
  border: none;
  box-shadow: none;
}

.shelf-photo {
  width: 100%;
  height: 100%;
  display: block;
  background: transparent;
}

.shelf-slot__del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 36rpx;
  line-height: 44rpx;
  text-align: center;
  z-index: 2;
}

.shelf-empty {
  padding: 80rpx 32rpx;
  text-align: center;
}

.shelf-empty__text {
  display: block;
  font-size: 30rpx;
  color: #8b7355;
}

.shelf-empty__hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #a08b6e;
}

.shelf-actions {
  padding: 24rpx 0;
}

.shelf-actions .weui-btn {
  width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  background: linear-gradient(135deg, #6f4e37, #8b5a3c);
  color: #fdf6ec;
}

