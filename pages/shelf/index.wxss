.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: radial-gradient(circle at top, #fdf6ec 0, #f7f3ee 45%, #f3eee8 100%);
}

.shelf-header {
  padding: 20rpx 0 28rpx;
  text-align: center;
}

.shelf-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #6f4e37;
}

.shelf-summary {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #6f4e37;
}

.shelf-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b7355;
}

.shelf-wrap {
  margin-bottom: 28rpx;
}

.shelf-row {
  position: relative;
  margin-bottom: 30rpx;
}

.shelf-board {
  position: absolute;
  left: -12rpx;
  right: -12rpx;
  bottom: 0;
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #8b6914 0, #6f4e37 32%, #5c3d2e 100%);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.18);
}

.shelf-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 0 8rpx 30rpx;
}

.shelf-slot {
  width: 22%;
  aspect-ratio: 1;
  position: relative;
  overflow: hidden;
  border-radius: 14rpx;
  border: 4rpx solid #e8dfd5;
  background: #f7f3ee;
  box-shadow: 0 6rpx 16rpx rgba(111, 78, 55, 0.14);
  box-sizing: border-box;
}

.shelf-slot--cutout {
  border: none;
  box-shadow: none;
  background: #f7f3ee;
}

.shelf-photo {
  width: 100%;
  height: 100%;
  display: block;
  background: transparent;
}

.shelf-empty {
  margin-top: 10rpx;
  padding: 72rpx 28rpx;
  border-radius: 16rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
}

.shelf-empty__text {
  display: block;
  font-size: 30rpx;
  color: #7c644f;
}

.shelf-empty__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #a08b6e;
  line-height: 1.5;
}

.shelf-actions {
  padding: 20rpx 0 8rpx;
}

.shelf-actions .weui-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  white-space: nowrap;
  font-size: 30rpx;
  background: linear-gradient(135deg, #6f4e37, #8b5a3c);
  color: #fdf6ec;
}
