.page {
  --bg1: #f6efe6;
  --bg2: #f2e6d8;
  --panel: rgba(255, 255, 255, 0.88);
  --text: #2f2218;
  --muted: #866f5b;
  --brand: #7f4f2a;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background: radial-gradient(circle at 15% 0%, var(--bg1), var(--bg2) 60%);
  color: var(--text);
}

.theme-matcha {
  --bg1: #edf4e5;
  --bg2: #dce8ce;
  --panel: rgba(249, 252, 245, 0.9);
  --text: #1f2a1f;
  --muted: #5a6a57;
  --brand: #4f6b43;
}

.theme-graphite {
  --bg1: #e9edf2;
  --bg2: #d7dde6;
  --panel: rgba(248, 250, 253, 0.9);
  --text: #202734;
  --muted: #5e6674;
  --brand: #3a4961;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--muted);
}

.controls,
.story-card,
.panel {
  margin-top: 22rpx;
  border-radius: 24rpx;
  padding: 22rpx;
  background: var(--panel);
  backdrop-filter: blur(6px);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row + .row {
  margin-top: 16rpx;
}

.label {
  font-size: 24rpx;
  color: var(--muted);
}

.chips {
  display: flex;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.6);
}

.chip--active {
  color: #fff;
  background: var(--brand);
}

.story-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.story-title {
  font-size: 34rpx;
  font-weight: 700;
}

.story-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.story-tag {
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #fff;
  background: linear-gradient(120deg, var(--brand), #b37d53);
}

.stats-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.stat {
  padding: 14rpx 10rpx;
  border-radius: 14rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.65);
}

.stat-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 4rpx;
  display: block;
  font-size: 20rpx;
  color: var(--muted);
}

.best-photo {
  margin-top: 20rpx;
  position: relative;
  border-radius: 18rpx;
  overflow: hidden;
  height: 350rpx;
}

.best-photo__img {
  width: 100%;
  height: 100%;
}

.best-photo__overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx;
  color: #fff;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.58), transparent);
}

.best-photo__title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
}

.best-photo__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  opacity: 0.92;
}

.caption {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.panel-title {
  font-size: 24rpx;
  font-weight: 600;
}

.thumb-scroll {
  margin-top: 14rpx;
  width: 100%;
}

.thumb-list {
  display: flex;
  gap: 14rpx;
  padding-bottom: 6rpx;
}

.thumb {
  position: relative;
  width: 154rpx;
  height: 154rpx;
  border-radius: 14rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
}

.thumb--active {
  border-color: var(--brand);
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-badge {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 10rpx;
  padding: 4rpx 8rpx;
}

.caption-input {
  margin-top: 14rpx;
  width: 100%;
  min-height: 150rpx;
  box-sizing: border-box;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #fff;
  font-size: 24rpx;
}

.actions {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.btn {
  margin: 0;
  line-height: 2.2;
  border: none;
  background: var(--brand);
  color: #fff;
  font-size: 22rpx;
}

.btn-ghost {
  background: rgba(127, 79, 42, 0.14);
  color: var(--brand);
}

.btn-share {
  background: linear-gradient(120deg, #2f8e3f, #1c7240);
}

.hint {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: var(--muted);
}
